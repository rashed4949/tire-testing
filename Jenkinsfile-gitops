pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID = "685368365467"
        AWS_REGION     = "eu-central-1"
        GITOPS_REPO    = "https://github.com/rashed4949/tire-testing-gitops-config"

        COMMIT_HASH  = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
        COMMIT_TIME  = sh(script: 'git log -1 --format=%cI', returnStdout: true).trim()
        DATE_VERSION = sh(script: 'date +%Y.%m.%d', returnStdout: true).trim()
    }

    stages {

        stage('Branch Check') {
            steps {
                script {
                    env.GIT_BRANCH_NAME = sh(
                        script: '''
                          git name-rev --name-only HEAD \
                          | sed 's|remotes/origin/||' \
                          | sed 's|~.*||'
                        ''',
                        returnStdout: true
                    ).trim()
                    if (env.GIT_BRANCH_NAME != 'main' && env.GIT_BRANCH_NAME != 'dev') {
                        currentBuild.result = 'NOT_BUILT'
                        error("Branch '${env.GIT_BRANCH_NAME}' is not dev or main — skipping pipeline.")
                    }
                }
            }
        }

        stage('Track Start') {
            steps {
                script {
                    env.PIPELINE_START = sh(script: 'date -Iseconds', returnStdout: true).trim()

                    if (env.GIT_BRANCH_NAME == 'main') {
                        env.BUILD_TYPE    = 'RELEASE'
                        env.ECR_REPO      = 'tire-testing-gitops-release'
                        env.GITOPS_PATH   = 'overlays/production'
                        env.ARGOCD_APP    = 'tire-testing-production'
                        env.K8S_NAMESPACE = 'production'
                    } else {
                        env.BUILD_TYPE    = 'SNAPSHOT'
                        env.ECR_REPO      = 'tire-testing-gitops-snapshot'
                        env.GITOPS_PATH   = 'overlays/staging'
                        env.ARGOCD_APP    = 'tire-testing-staging'
                        env.K8S_NAMESPACE = 'staging'
                    }

                    env.ECR_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                    env.IMAGE_TAG    = "${env.DATE_VERSION}-${env.BUILD_NUMBER}"

                    echo """
                      PIPELINE 3 — GITOPS
                      Branch:    ${env.GIT_BRANCH_NAME}
                      Type:      ${env.BUILD_TYPE}
                      Repo:      ${env.ECR_REPO}
                      Tag:       ${env.IMAGE_TAG}
                      ArgoApp:   ${env.ARGOCD_APP}
                      Namespace: ${env.K8S_NAMESPACE}
                    """
                }
            }
        }

        stage('Build — JAR + React') {
            steps {
                dir('backend') {
                    sh 'mvn clean package -DskipTests -B --no-transfer-progress'
                }
                script { env.BUILD_END = sh(script: 'date -Iseconds', returnStdout: true).trim() }
            }
        }

        stage('Test') {
            steps {
                dir('backend') {
                    sh 'mvn test -B --no-transfer-progress'
                }
            }
            post {
                always { junit allowEmptyResults: true, testResults: 'backend/target/surefire-reports/*.xml' }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                  docker build \
                    --tag ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG} \
                    --label "git-commit=${COMMIT_HASH}" \
                    --label "build-number=${BUILD_NUMBER}" \
                    .
                """
            }
        }

        stage('Push to ECR') {
            steps {
                sh """
                  aws ecr get-login-password --region ${AWS_REGION} \
                    | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                  docker push ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        stage('Update GitOps Repo') {
            steps {
                script { env.DEPLOY_START = sh(script: 'date -Iseconds', returnStdout: true).trim() }

                withCredentials([usernamePassword(credentialsId: 'github-creds', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh """
                      rm -rf gitops-tmp
                      git clone https://\$GIT_USER:\$GIT_TOKEN@github.com/rashed4949/tire-testing-gitops-config gitops-tmp
                      cd gitops-tmp/${GITOPS_PATH}

                      # Update the image tag in the overlay's patch file
                      sed -i "s|${ECR_REPO}:.*|${ECR_REPO}:${IMAGE_TAG}|" patch-image.yaml

                      git config user.email "jenkins@thesis.local"
                      git config user.name "Jenkins CI"
                      git add patch-image.yaml
                      git commit -m "Deploy ${ECR_REPO}:${IMAGE_TAG} (${COMMIT_HASH}) to ${K8S_NAMESPACE}" || echo "No changes to commit"
                      git push
                    """
                }
            }
        }

        stage('Wait for ArgoCD Sync') {
            steps {
                sh """
                  argocd app sync ${ARGOCD_APP} --server localhost:8443 --insecure
                  argocd app wait ${ARGOCD_APP} --server localhost:8443 --insecure --health --timeout 300
                """
                script { env.DEPLOY_END = sh(script: 'date -Iseconds', returnStdout: true).trim() }
            }
        }

        stage('Verify Deployment') {
            steps {
                sh """
                  kubectl wait --for=condition=ready pod -l app=tire-testing -n ${K8S_NAMESPACE} --timeout=180s
                  kubectl get pods -n ${K8S_NAMESPACE}
                """
            }
        }

        stage('Log DORA Metrics') {
            steps {
                sh """
                  mkdir -p /var/log/dora
                  echo "${COMMIT_HASH},${COMMIT_TIME},${env.PIPELINE_START},${env.BUILD_END},${env.DEPLOY_START},${env.DEPLOY_END},${env.IMAGE_TAG},${env.BUILD_TYPE},SUCCESS,gitops" \
                    >> /var/log/dora/metrics.csv
                """
            }
        }

        stage('Grafana Deployment Annotation') {
            when { expression { return currentBuild.result == null || currentBuild.result == 'SUCCESS' } }
            steps {
                script {
                    try {
                        withCredentials([string(credentialsId: 'grafana-api-key', variable: 'GRAFANA_KEY')]) {
                            sh """
                              curl -s -X POST \
                                "http://10.0.1.242:3000/api/annotations" \
                                -H "Content-Type: application/json" \
                                -H "Authorization: Bearer \$GRAFANA_KEY" \
                                -d '{
                                  "text": "Deployed ${BUILD_TYPE} ${IMAGE_TAG} (${COMMIT_HASH}) via ArgoCD to ${K8S_NAMESPACE}",
                                  "tags": ["deployment","gitops","tire-testing","${BUILD_TYPE}"],
                                  "time": '\$(date +%s%3N)'
                                }' || echo "Grafana annotation skipped (not critical)"
                            """
                        }
                    } catch(err) {
                        echo "Grafana annotation failed (not critical): ${err}"
                    }
                }
            }
        }
    }

    post {
        failure {
            sh """
              mkdir -p /var/log/dora
              echo "${COMMIT_HASH},${COMMIT_TIME},${env.PIPELINE_START},${env.BUILD_END ?: ''},${env.DEPLOY_START ?: ''},\$(date -Iseconds),${env.IMAGE_TAG ?: ''},${env.BUILD_TYPE ?: 'UNKNOWN'},FAILED,gitops" \
                >> /var/log/dora/metrics.csv
            """
        }
        success {
            echo "Pipeline 3 (GitOps) — ${env.BUILD_TYPE} ${env.IMAGE_TAG} synced to ${env.K8S_NAMESPACE} via ArgoCD."
        }
        always {
            sh 'rm -rf gitops-tmp'
            sh 'docker image prune -f --filter "until=24h" || true'
        }
    }
}